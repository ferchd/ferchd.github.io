<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Términos y Condiciones — Aequo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="icon" type="image/x-icon" href="favicon.ico">
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Montserrat:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">
  <style>
    :root {
      --primary: #34146c;
      --primary-container: #4b2e83;
      --primary-fixed: #e8ddf5;
      --secondary: #9a7cbf;
      --surface: #fef7ff;
      --surface-container: #f3ebf7;
      --surface-container-low: #f9f1fc;
      --surface-container-lowest: #ffffff;
      --surface-container-highest: #e7e0eb;
      --surface-variant: #e7e0eb;
      --on-surface: #1d1a22;
      --on-surface-variant: #4a4458;
      --outline-variant: #cbc4d2;
      --error: #ba1a1a;
    }

    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      font-size: 16px;
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--surface);
      color: var(--on-surface);
      min-height: 100vh;
      overflow-x: hidden;
      position: relative;
    }

    .ambient-orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.18;
      pointer-events: none;
      z-index: 0;
    }

    .ambient-orb--1 {
      width: 500px;
      height: 500px;
      background: var(--primary);
      top: -200px;
      right: -100px;
    }

    .ambient-orb--2 {
      width: 400px;
      height: 400px;
      background: var(--secondary);
      bottom: -150px;
      left: -100px;
    }

    .page {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .nav {
      padding: 2rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      animation: fadeSlideDown 0.8s ease-out both;
    }

    .nav__brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
    }

    .nav__logo {
      width: 32px;
      height: 32px;
      object-fit: contain;
    }

    .nav__name {
      font-family: 'Manrope', sans-serif;
      font-weight: 700;
      font-size: 1.15rem;
      color: var(--on-surface);
      letter-spacing: -0.02em;
    }

    .nav__back {
      font-family: 'Manrope', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--on-surface-variant);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      transition: color 0.25s ease;
    }

    .nav__back:hover {
      color: var(--primary);
    }

    .nav__back svg {
      width: 16px;
      height: 16px;
    }

    .content {
      flex: 1;
      max-width: 780px;
      margin: 0 auto;
      padding: 1rem 3rem 4rem;
      width: 100%;
      animation: fadeSlideUp 0.9s 0.15s ease-out both;
    }

    .content__badge {
      font-family: 'Manrope', sans-serif;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--primary);
      background: var(--primary-fixed);
      padding: 0.3rem 0.85rem;
      border-radius: 9999px;
      display: inline-block;
      margin-bottom: 1.25rem;
    }

    .content__title {
      font-family: 'Manrope', sans-serif;
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.035em;
      line-height: 1.1;
      color: var(--on-surface);
      margin-bottom: 0.75rem;
    }

    .content__title span {
      background: linear-gradient(135deg, var(--primary), var(--primary-container));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .content__updated {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.78rem;
      color: var(--outline-variant);
      margin-bottom: 3rem;
    }

    .section {
      margin-bottom: 2.5rem;
    }

    .section__heading {
      font-family: 'Manrope', sans-serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--on-surface);
      letter-spacing: -0.01em;
      margin-bottom: 0.75rem;
    }

    .section__text {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.9rem;
      color: var(--on-surface-variant);
      line-height: 1.75;
    }

    .section__text+.section__text {
      margin-top: 0.75rem;
    }

    .highlight-box {
      background: var(--surface-container-low);
      border-radius: 1.5rem;
      padding: 1.5rem 1.75rem;
      margin-top: 1rem;
    }

    .highlight-box__item {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.85rem;
      color: var(--on-surface-variant);
      line-height: 1.7;
      padding: 0.35rem 0;
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
    }

    .highlight-box__item::before {
      content: '';
      width: 5px;
      height: 5px;
      min-width: 5px;
      background: var(--primary);
      border-radius: 50%;
      margin-top: 0.55rem;
    }

    .footer {
      padding: 2rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      animation: fadeSlideUp 1s 0.6s ease-out both;
    }

    .footer__copy {
      font-size: 0.75rem;
      color: var(--outline-variant);
    }

    .footer__links {
      display: flex;
      gap: 1.5rem;
    }

    .footer__link {
      font-family: 'Manrope', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--on-surface-variant);
      text-decoration: none;
      transition: color 0.25s ease;
    }

    .footer__link:hover {
      color: var(--primary);
    }

    @keyframes fadeSlideUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes fadeSlideDown {
      from {
        opacity: 0;
        transform: translateY(-16px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 768px) {
      .nav {
        padding: 1.5rem;
      }

      .content {
        padding: 1rem 1.5rem 3rem;
      }

      .content__title {
        font-size: 1.8rem;
      }

      .footer {
        padding: 1.5rem;
        flex-direction: column;
        gap: 1rem;
        text-align: center;
      }
    }
  </style>
</head>

<body>

  <div class="ambient-orb ambient-orb--1"></div>
  <div class="ambient-orb ambient-orb--2"></div>

  <div class="page">

    <nav class="nav">
      <a href="/" class="nav__brand">
        <img src="aequo-logo.png" alt="Aequo" class="nav__logo">
        <span class="nav__name">Aequo</span>
      </a>
      <a href="/" class="nav__back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Volver al inicio
      </a>
    </nav>

    <main class="content">

      <span class="content__badge">Legal</span>
      <h1 class="content__title">Términos y <span>Condiciones</span></h1>
      <p class="content__updated">Última actualización: 19 de marzo de 2026</p>

      <div class="section">
